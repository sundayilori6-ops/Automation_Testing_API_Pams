{
  "name": "automation-testing-api-pams",
  "version": "1.0.0",
  "type": "module",
  "description": "API Testing and Automation with Jest and Axios",
  "main": "index.js",
  "scripts": {
    "test": "jest --runInBand",
    "test:verbose": "jest --runInBand --verbose",
    "test:coverage": "jest --runInBand --coverage"
  },
  "keywords": [],
  "author": "Pams",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "testMatch": ["**/tests/**/*.test.js"],
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "reports",
          "outputName": "junit.xml"
        }
      ]
    ]
  }
}
